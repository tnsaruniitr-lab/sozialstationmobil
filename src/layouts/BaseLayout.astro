---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatBot from '../components/ChatBot.astro';
import { company, seoDefaults } from '../data/site';
import { buildGraph, breadcrumbSchema, webPageSchema } from '../lib/schema';

interface Props {
  title: string;
  description?: string;
  rawTitle?: boolean;
  image?: string;
  noindex?: boolean;
  breadcrumbs?: { name: string; href: string }[];
  schema?: object[];
}

const {
  title,
  description = seoDefaults.defaultDescription,
  rawTitle = false,
  image = '/og-default.png',
  noindex = false,
  breadcrumbs,
  schema = [],
} = Astro.props;

const pageTitle = rawTitle ? title : `${title} | Sozialstation Mobil Berlin`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

// WebPage-Knoten (mit dateModified) + ggf. Breadcrumb-Schema ergänzen
const extraSchema = [
  webPageSchema({ url: canonical, name: pageTitle, description }),
  ...schema,
];
if (breadcrumbs && breadcrumbs.length > 1) {
  extraSchema.push(breadcrumbSchema([{ name: 'Startseite', href: '/' }, ...breadcrumbs.slice(1)]));
}
const jsonLd = buildGraph(extraSchema);
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- Einsprachige Website (Deutsch) – selbstreferenzierendes hreflang + x-default -->
    <link rel="alternate" hreflang="de" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />

    <meta name="theme-color" content={seoDefaults.themeColor} />
    <meta name="author" content={company.legalName} />
    <meta name="generator" content={Astro.generator} />

    <!-- Lokale Geo-Signale -->
    <meta name="geo.region" content="DE-BE" />
    <meta name="geo.placename" content="Berlin-Reinickendorf" />
    <meta name="geo.position" content={`${company.geo.lat};${company.geo.lng}`} />
    <meta name="ICBM" content={`${company.geo.lat}, ${company.geo.lng}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={seoDefaults.locale} />
    <meta property="og:site_name" content={seoDefaults.siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Sozialstation Mobil – Ambulanter Pflegedienst in Berlin-Reinickendorf" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color={seoDefaults.themeColor} />

    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Strukturierte Daten -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <a
      href="#hauptinhalt"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-brand-700 focus:px-5 focus:py-3 focus:text-white focus:shadow-lift"
    >
      Zum Hauptinhalt springen
    </a>
    <Header />
    <main id="hauptinhalt">
      <slot />
    </main>
    <Footer />
    <ChatBot />
  </body>
</html>
