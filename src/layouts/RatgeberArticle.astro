---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import CtaBand from '../components/CtaBand.astro';
import { company, ratgeberArticles, getService, type Faq } from '../data/site';
import { articleSchema, faqSchema } from '../lib/schema';

interface Props {
  slug: string;
  title: string;
  description: string;
  excerpt: string;
  faqs?: Faq[];
  relatedServices?: string[];
}
const { slug, title, description, excerpt, faqs = [], relatedServices = [] } = Astro.props;

const url = `/ratgeber/${slug}/`;
const breadcrumbs = [
  { name: 'Startseite', href: '/' },
  { name: 'Ratgeber', href: '/ratgeber/' },
  { name: title, href: url },
];

const schema = [articleSchema({ headline: title, description, url })];
if (faqs.length) schema.push(faqSchema(faqs));

const otherArticles = ratgeberArticles.filter((a) => a.slug !== slug);
const services = relatedServices.map((s) => getService(s)).filter(Boolean);
---
<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} schema={schema}>
  <section class="bg-gradient-to-b from-brand-50 to-sand-50">
    <div class="container-page py-10 lg:py-14">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 max-w-3xl">
        <p class="eyebrow"><Icon name="clipboard" class="h-4 w-4" /> Ratgeber</p>
        <h1 class="mt-3 font-display text-4xl font-extrabold leading-tight text-brand-950 md:text-5xl">{title}</h1>
        <p class="mt-5 text-lg text-ink-soft">{excerpt}</p>
        <p class="mt-5 flex flex-wrap items-center gap-x-2.5 gap-y-1 text-sm text-ink-soft">
          <span class="inline-flex items-center gap-2">
            <Icon name="shield" class="h-4 w-4 text-brand-500" />
            Fachlich verantwortlich: <strong class="font-semibold text-ink">{company.managingDirector}</strong>, Geschäftsführer
          </span>
          <span class="text-sand-400" aria-hidden="true">·</span>
          <span>Stand: Mai 2026</span>
        </p>
      </div>
    </div>
  </section>

  <div class="container-page grid gap-12 py-14 md:py-16 lg:grid-cols-[1fr_320px]">
    <div class="min-w-0">
      <article class="prose-care max-w-none">
        <slot />
      </article>

      <!-- Pflichthinweis: keine Rechtsberatung -->
      <p class="mt-10 rounded-2xl border border-sand-200 bg-sand-100 px-5 py-4 text-sm text-ink-soft">
        <strong class="text-ink">Hinweis:</strong> Dieser Ratgeber dient der allgemeinen Information und
        ersetzt keine individuelle Rechts-, Sozial- oder Pflegeberatung. Gesetzliche Leistungen und Beträge
        (Stand 2025) werden regelmäßig angepasst – die für Sie gültigen Werte erfahren Sie bei Ihrer
        Pflege- bzw. Krankenkasse oder in einem persönlichen Gespräch mit uns.
      </p>

      {faqs.length > 0 && (
        <section class="mt-12">
          <h2 class="font-display text-2xl font-extrabold text-brand-950">Häufige Fragen</h2>
          <div class="mt-6">
            <FaqAccordion items={faqs} />
          </div>
        </section>
      )}

      {services.length > 0 && (
        <section class="mt-12">
          <h2 class="font-display text-2xl font-extrabold text-brand-950">Passende Leistungen</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            {services.map((s) => (
              <a href={`/leistungen/${s!.slug}/`} class="group card flex items-start gap-4 p-5 transition-all hover:-translate-y-1 hover:shadow-lift">
                <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-accent-500 group-hover:text-white">
                  <Icon name={s!.icon} class="h-6 w-6" />
                </span>
                <span>
                  <span class="block font-display font-bold text-brand-950">{s!.title}</span>
                  <span class="mt-1 block text-sm text-ink-soft">{s!.short}</span>
                </span>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Sidebar -->
    <aside class="space-y-6 lg:sticky lg:top-28 lg:h-fit">
      <div class="rounded-[2rem] bg-brand-800 p-7 text-white shadow-lift">
        <Icon name="heart-hands" class="h-10 w-10 text-accent-300" />
        <h2 class="mt-4 font-display text-xl font-bold">Persönlich beraten lassen</h2>
        <p class="mt-2 text-brand-100">
          Jede Situation ist anders. In einem kostenlosen Gespräch klären wir Ihre Fragen
          ganz konkret – unverbindlich und auf Augenhöhe.
        </p>
        <a href="/kontakt/" class="btn btn-primary mt-6 w-full">Beratung anfragen</a>
        <a href={`tel:${company.phoneHref}`} class="mt-4 flex items-center justify-center gap-2 font-display font-bold text-white hover:text-accent-300">
          <Icon name="phone" class="h-5 w-5" />
          {company.phone}
        </a>
      </div>

      <nav class="card p-6" aria-label="Weitere Ratgeber-Artikel">
        <h2 class="font-display text-sm font-bold uppercase tracking-wider text-brand-900">Weitere Ratgeber</h2>
        <ul class="mt-4 space-y-1">
          {otherArticles.map((a) => (
            <li>
              <a href={`/ratgeber/${a.slug}/`} class="flex items-center gap-3 rounded-xl px-2 py-2.5 text-ink transition-colors hover:bg-sand-50 hover:text-brand-700">
                <Icon name={a.icon} class="h-5 w-5 shrink-0 text-brand-500" />
                <span class="font-semibold">{a.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  </div>

  <CtaBand />
</BaseLayout>
