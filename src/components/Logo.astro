---
/**
 * Wort-Bild-Marke der Sozialstation Mobil.
 * Bildmarke = Standort-Pin mit Herz (steht für "mobile Pflege, die zu Ihnen kommt").
 */
interface Props {
  tone?: 'dark' | 'light';
  showTagline?: boolean;
  class?: string;
}
const { tone = 'dark', showTagline = true, class: className = '' } = Astro.props;

const wordColor = tone === 'light' ? 'text-white' : 'text-brand-950';
const taglineColor = tone === 'light' ? 'text-brand-100/80' : 'text-ink-soft';
const gid = 'logo-grad';
---
<span class={`inline-flex items-center gap-2.5 ${className}`}>
  <svg class="h-10 w-10 shrink-0" viewBox="0 0 48 48" aria-hidden="true">
    <defs>
      <linearGradient id={gid} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#2a82b5" />
        <stop offset="1" stop-color="#1d4b6a" />
      </linearGradient>
    </defs>
    <path
      d="M24 3C15.4 3 8.5 9.9 8.5 18.5c0 10.8 13.4 24.2 15 25.7a.7.7 0 0 0 1 0c1.6-1.5 15-14.9 15-25.7C39.5 9.9 32.6 3 24 3Z"
      fill={`url(#${gid})`}
    />
    <path
      d="M24 27.6c-4.3-3.9-7.9-6.5-7.9-9.8 0-2.1 1.7-3.6 3.7-3.6 1.7 0 3 1 4.2 2.9 1.2-1.9 2.5-2.9 4.2-2.9 2 0 3.7 1.5 3.7 3.6 0 3.3-3.6 5.9-7.9 9.8Z"
      fill="#ffffff"
    />
    <circle cx="35" cy="11" r="3.4" fill="#fb6a13" />
    <circle cx="35" cy="11" r="3.4" fill="none" stroke="#ffffff" stroke-width="1.4" opacity="0.55" />
  </svg>
  <span class="flex flex-col leading-none">
    <span class={`font-display text-xl font-extrabold tracking-tight ${wordColor}`}>
      Sozialstation<span class="text-accent-500"> Mobil</span>
    </span>
    {showTagline && (
      <span class={`mt-1 text-[0.7rem] font-semibold uppercase tracking-[0.14em] ${taglineColor}`}>
        Ambulanter Pflegedienst · Berlin
      </span>
    )}
  </span>
</span>
