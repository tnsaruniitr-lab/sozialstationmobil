---
/**
 * Hero-Illustration: häusliche Pflege – eine Pflegekraft begleitet einen
 * älteren Menschen. Warm, freundlich, markenkonform (Blau/Orange).
 * Reines SVG → gestochen scharf, leicht, kein externer Request.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<svg
  class={className}
  viewBox="0 0 600 500"
  fill="none"
  role="img"
  aria-label="Eine Pflegekraft der Sozialstation Mobil begleitet einfühlsam einen älteren Menschen zu Hause."
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id="ha-chair" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#ffffff" />
      <stop offset="1" stop-color="#f4f1ea" />
    </linearGradient>
    <linearGradient id="ha-scrubs" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#2a82b5" />
      <stop offset="1" stop-color="#1f6c9b" />
    </linearGradient>
  </defs>

  <!-- Hintergrund-Dekor -->
  <circle cx="468" cy="118" r="66" fill="#ffe9d4" />
  <circle cx="120" cy="150" r="34" fill="#d7ecf7" />
  <circle cx="64" cy="300" r="14" fill="#ffcfa8" />
  <circle cx="540" cy="250" r="10" fill="#82c2e2" />

  <!-- Boden / Teppich -->
  <ellipse cx="312" cy="438" rx="250" ry="36" fill="#e9e3d6" />
  <ellipse cx="312" cy="438" rx="180" ry="24" fill="#ddd3c0" />

  <!-- Zimmerpflanze rechts -->
  <g>
    <path d="M508 372c-2-26 6-46 18-58-2 22-6 40-18 58Z" fill="#5aa472" />
    <path d="M508 374c-14-20-18-42-14-60 14 16 22 38 14 60Z" fill="#6fb588" />
    <path d="M508 374c10-22 28-34 46-36-12 18-28 32-46 36Z" fill="#4f9968" />
    <path d="M494 372h32l-5 46a6 6 0 0 1-6 5h-10a6 6 0 0 1-6-5Z" fill="#ec5009" />
    <path d="M494 372h32l-2 14h-28Z" fill="#c33c0a" />
  </g>

  <!-- Sessel -->
  <g>
    <rect x="296" y="182" width="166" height="170" rx="34" fill="url(#ha-chair)" stroke="#e9e3d6" stroke-width="2" />
    <rect x="312" y="300" width="150" height="74" rx="26" fill="#d7ecf7" />
    <rect x="286" y="262" width="30" height="104" rx="15" fill="#ffffff" stroke="#e9e3d6" stroke-width="2" />
    <rect x="450" y="262" width="30" height="104" rx="15" fill="#ffffff" stroke="#e9e3d6" stroke-width="2" />
    <rect x="320" y="372" width="18" height="46" rx="6" fill="#cbb596" />
    <rect x="436" y="372" width="18" height="46" rx="6" fill="#cbb596" />
  </g>

  <!-- Älterer Mensch, sitzend -->
  <g>
    <!-- Beine -->
    <path d="M356 350c0 24-2 44-2 56h26l4-58Z" fill="#7a8aa0" />
    <path d="M404 350c2 24 4 44 6 56h-26l-4-58Z" fill="#8a99ad" />
    <ellipse cx="350" cy="412" rx="16" ry="9" fill="#46566a" />
    <ellipse cx="410" cy="412" rx="16" ry="9" fill="#46566a" />
    <!-- Oberkörper / Strickjacke -->
    <path d="M344 268c0-20 16-32 38-32s38 12 38 32v44c0 12-10 22-22 22h-32c-12 0-22-10-22-22Z" fill="#ffcfa8" />
    <path d="M382 236c10 0 19 3 26 9l-26 24-26-24c7-6 16-9 26-9Z" fill="#ffe9d4" />
    <!-- Arme ruhend -->
    <rect x="330" y="284" width="20" height="56" rx="10" fill="#ffac70" />
    <rect x="414" y="284" width="20" height="56" rx="10" fill="#ffac70" />
    <circle cx="340" cy="342" r="11" fill="#f1c4a0" />
    <circle cx="424" cy="342" r="11" fill="#f1c4a0" />
    <!-- Kopf -->
    <circle cx="382" cy="208" r="30" fill="#f3d0b3" />
    <path d="M352 206a30 30 0 0 1 60 0c0-6-3-22-30-22s-30 16-30 22Z" fill="#cfd6df" />
    <path d="M352 206c-2 8 0 14 4 18-6-2-10-10-8-20Zm60 0c2 8 0 14-4 18 6-2 10-10 8-20Z" fill="#dde2e9" />
    <!-- Freundliches Gesicht -->
    <circle cx="373" cy="208" r="2.6" fill="#46566a" />
    <circle cx="392" cy="208" r="2.6" fill="#46566a" />
    <path d="M375 218c3 3 9 3 12 0" stroke="#b06a4a" stroke-width="2.4" stroke-linecap="round" />
    <circle cx="368" cy="215" r="4" fill="#ffb89a" opacity="0.6" />
    <circle cx="397" cy="215" r="4" fill="#ffb89a" opacity="0.6" />
  </g>

  <!-- Pflegekraft, stehend, Hand auf der Schulter -->
  <g>
    <!-- Beine / Hose -->
    <rect x="196" y="316" width="26" height="104" rx="12" fill="#1d4b6a" />
    <rect x="228" y="316" width="26" height="104" rx="12" fill="#1d597f" />
    <ellipse cx="208" cy="424" rx="17" ry="9" fill="#13283c" />
    <ellipse cx="240" cy="424" rx="17" ry="9" fill="#13283c" />
    <!-- Kasack / Oberteil -->
    <path d="M182 244c0-22 16-36 42-36s42 14 42 36v60c0 10-8 18-18 18h-48c-10 0-18-8-18-18Z" fill="url(#ha-scrubs)" />
    <path d="M224 208c8 0 15 2 21 6l-21 22-21-22c6-4 13-6 21-6Z" fill="#3b86b8" />
    <path d="M250 256l8 4-8 18Z" fill="#1d597f" />
    <!-- Brusttasche + Pflege-Kreuz -->
    <rect x="236" y="262" width="22" height="20" rx="4" fill="#4aa1cf" />
    <path d="M246 266v12M241 272h10" stroke="#ffffff" stroke-width="2.2" stroke-linecap="round" />
    <!-- linker Arm hängend -->
    <rect x="178" y="262" width="20" height="60" rx="10" fill="#2a82b5" />
    <circle cx="188" cy="324" r="11" fill="#f1c4a0" />
    <!-- rechter Arm reicht zur Schulter des Seniors -->
    <path d="M260 268c22 2 40 0 58 -8" stroke="#2a82b5" stroke-width="22" stroke-linecap="round" />
    <circle cx="324" cy="258" r="13" fill="#f1c4a0" />
    <!-- Kopf + Dutt -->
    <circle cx="224" cy="186" r="29" fill="#f1c4a0" />
    <path d="M196 188a28 28 0 0 1 56 0c0-16-8-30-28-30s-28 14-28 30Z" fill="#46566a" />
    <circle cx="224" cy="150" r="9" fill="#46566a" />
    <!-- Gesicht -->
    <circle cx="216" cy="187" r="2.6" fill="#3a4654" />
    <circle cx="234" cy="187" r="2.6" fill="#3a4654" />
    <path d="M217 196c3 3 9 3 12 0" stroke="#b06a4a" stroke-width="2.4" stroke-linecap="round" />
    <circle cx="210" cy="194" r="4" fill="#ffb89a" opacity="0.6" />
    <circle cx="238" cy="194" r="4" fill="#ffb89a" opacity="0.6" />
  </g>

  <!-- Schwebendes Herz -->
  <g>
    <path d="M300 96c-3-7-9-10-15-10-9 0-15 7-15 16 0 11 13 19 30 33 17-14 30-22 30-33 0-9-6-16-15-16-6 0-12 3-15 10Z" fill="#fb6a13" />
    <circle cx="276" cy="70" r="3" fill="#ffcfa8" />
    <circle cx="332" cy="86" r="4" fill="#ffac70" />
  </g>
</svg>
