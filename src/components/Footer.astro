---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { company, services, serviceAreas } from '../data/site';

const year = 2026;
---
<footer class="bg-brand-950 text-brand-100">
  <div class="container-page py-14 md:py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-12">
      <!-- Marke -->
      <div class="lg:col-span-4">
        <Logo tone="light" />
        <p class="mt-5 max-w-sm text-brand-200/90">
          Ihr ambulanter Fachpflegedienst in Berlin-Reinickendorf. Mit Herz, Erfahrung
          und Fachkompetenz – damit Pflege zuhause gelingt.
        </p>
        <div class="mt-6 flex items-center gap-3">
          <a
            href={company.social.facebook}
            class="grid h-11 w-11 place-items-center rounded-full bg-white/10 text-white transition-colors hover:bg-accent-500"
            aria-label="Sozialstation Mobil auf Facebook"
            rel="noopener"
            target="_blank"
          >
            <Icon name="facebook" class="h-5 w-5" />
          </a>
          <a
            href={company.social.instagram}
            class="grid h-11 w-11 place-items-center rounded-full bg-white/10 text-white transition-colors hover:bg-accent-500"
            aria-label="Sozialstation Mobil auf Instagram"
            rel="noopener"
            target="_blank"
          >
            <Icon name="instagram" class="h-5 w-5" />
          </a>
        </div>
      </div>

      <!-- Leistungen -->
      <div class="lg:col-span-3">
        <h2 class="font-display text-sm font-bold uppercase tracking-wider text-white">Leistungen</h2>
        <ul class="mt-4 space-y-2.5">
          {services.map((s) => (
            <li>
              <a href={`/leistungen/${s.slug}/`} class="text-brand-200/90 transition-colors hover:text-accent-300">
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Unternehmen -->
      <div class="lg:col-span-2">
        <h2 class="font-display text-sm font-bold uppercase tracking-wider text-white">Unternehmen</h2>
        <ul class="mt-4 space-y-2.5">
          <li><a href="/ueber-uns/" class="text-brand-200/90 transition-colors hover:text-accent-300">Über uns</a></li>
          <li><a href="/team/" class="text-brand-200/90 transition-colors hover:text-accent-300">Team</a></li>
          <li><a href="/karriere/" class="text-brand-200/90 transition-colors hover:text-accent-300">Karriere</a></li>
          <li><a href="/ratgeber/pflegekosten-pflegegrad/" class="text-brand-200/90 transition-colors hover:text-accent-300">Pflegekosten &amp; Pflegegrad</a></li>
          <li><a href="/kontakt/" class="text-brand-200/90 transition-colors hover:text-accent-300">Kontakt</a></li>
        </ul>
      </div>

      <!-- Kontakt -->
      <div class="lg:col-span-3">
        <h2 class="font-display text-sm font-bold uppercase tracking-wider text-white">Kontakt</h2>
        <address class="mt-4 space-y-3 not-italic text-brand-200/90">
          <p class="flex items-start gap-3">
            <Icon name="pin" class="mt-0.5 h-5 w-5 shrink-0 text-accent-400" />
            <span>{company.address.street}<br />{company.address.postalCode} {company.address.city}</span>
          </p>
          <p>
            <a href={`tel:${company.phoneHref}`} class="flex items-center gap-3 font-semibold text-white hover:text-accent-300">
              <Icon name="phone" class="h-5 w-5 shrink-0 text-accent-400" />
              {company.phone}
            </a>
          </p>
          <p>
            <a href={`mailto:${company.email}`} class="flex items-center gap-3 hover:text-accent-300">
              <Icon name="mail" class="h-5 w-5 shrink-0 text-accent-400" />
              {company.email}
            </a>
          </p>
          <p class="flex items-start gap-3">
            <Icon name="clock" class="mt-0.5 h-5 w-5 shrink-0 text-accent-400" />
            <span>Büro: Mo–Fr 8:00–16:30 Uhr<br /><span class="text-accent-300">Pflege: rund um die Uhr</span></span>
          </p>
        </address>
      </div>
    </div>

    <!-- Versorgungsgebiet -->
    <div class="mt-12 border-t border-white/10 pt-8">
      <p class="font-display text-sm font-bold uppercase tracking-wider text-white">Unser Versorgungsgebiet</p>
      <ul class="mt-3 flex flex-wrap gap-2">
        {serviceAreas.map((area) => (
          <li class="rounded-full bg-white/10 px-3.5 py-1.5 text-sm text-brand-100">{area}</li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Schlussleiste -->
  <div class="border-t border-white/10">
    <div class="container-page flex flex-col items-center justify-between gap-4 py-6 text-sm text-brand-300 sm:flex-row">
      <p>© {year} {company.legalName}. Alle Rechte vorbehalten.</p>
      <ul class="flex items-center gap-6">
        <li><a href="/impressum/" class="hover:text-accent-300">Impressum</a></li>
        <li><a href="/datenschutz/" class="hover:text-accent-300">Datenschutz</a></li>
      </ul>
    </div>
  </div>
</footer>
