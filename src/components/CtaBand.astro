---
import Icon from './Icon.astro';
import { company } from '../data/site';
interface Props {
  title?: string;
  text?: string;
}
const {
  title = 'Lassen Sie uns über Ihre Situation sprechen.',
  text = 'Ein kostenloses, unverbindliches Beratungsgespräch klärt alle Fragen zu Leistungen, Pflegegrad und Kosten – gerne bei Ihnen zu Hause.',
} = Astro.props;
---
<section class="container-page py-16 md:py-20">
  <div class="relative overflow-hidden rounded-[2.5rem] bg-brand-800 px-6 py-12 text-white shadow-lift md:px-14 md:py-16">
    <!-- Dekor -->
    <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-brand-700/60"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-10 h-56 w-56 rounded-full bg-accent-500/15"></div>
    <div class="pointer-events-none absolute right-10 bottom-8 hidden text-accent-400/30 lg:block">
      <Icon name="heart" class="h-28 w-28" />
    </div>

    <div class="relative max-w-2xl">
      <p class="eyebrow text-accent-300">Wir sind für Sie da</p>
      <h2 class="mt-3 font-display text-3xl font-extrabold text-white md:text-4xl">{title}</h2>
      <p class="mt-4 text-lg text-brand-100">{text}</p>
      <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a href={`tel:${company.phoneHref}`} class="btn btn-primary text-lg">
          <Icon name="phone" class="h-5 w-5" />
          {company.phone}
        </a>
        <a href="/kontakt/" class="btn btn-secondary">
          Rückruf vereinbaren
        </a>
      </div>
    </div>
  </div>
</section>
