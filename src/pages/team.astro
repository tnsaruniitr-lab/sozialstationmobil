---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CtaBand from '../components/CtaBand.astro';

const breadcrumbs = [
  { name: 'Startseite', href: '/' },
  { name: 'Team', href: '/team/' },
];

// Rollen-basierte Darstellung. Echte Namen & Fotos vor Live-Gang ergänzen.
const roles = [
  { icon: 'clipboard', title: 'Pflegedienstleitung', text: 'Koordiniert Ihre Versorgung, plant die Einsätze und ist Ihre zentrale Ansprechperson.', color: 'brand' },
  { icon: 'stethoscope', title: 'Examinierte Pflegefachkräfte', text: 'Übernehmen Grund- und Behandlungspflege auf ärztliche Verordnung – fachkundig und einfühlsam.', color: 'accent' },
  { icon: 'bandage', title: 'Wundexpert:innen', text: 'Speziell weitergebildet für die moderne, phasengerechte Versorgung chronischer Wunden.', color: 'brand' },
  { icon: 'droplet', title: 'Diabetes-Fachkräfte', text: 'Unterstützen sicher bei Insulingabe, Blutzuckereinstellung und der Vorbeugung von Folgen.', color: 'accent' },
  { icon: 'companion', title: 'Betreuungs- & Alltagskräfte', text: 'Schenken Zeit, Gesellschaft und Begleitung – und entlasten pflegende Angehörige.', color: 'brand' },
  { icon: 'phone', title: 'Verwaltung & Koordination', text: 'Kümmert sich um Termine, Abrechnung mit den Kassen und Ihre Fragen rund um die Organisation.', color: 'accent' },
];
---
<BaseLayout
  title="Unser Team – Pflege mit vertrauten Gesichtern"
  description="Das Team der Sozialstation Mobil: examinierte Pflegefachkräfte, Wundexpert:innen, Betreuungskräfte und ein erfahrenes Koordinationsteam für Ihre Versorgung in Berlin-Reinickendorf."
  breadcrumbs={breadcrumbs}
>
  <section class="bg-gradient-to-b from-brand-50 to-sand-50">
    <div class="container-page py-10 lg:py-16">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 max-w-3xl">
        <p class="eyebrow">Unser Team</p>
        <h1 class="mt-3 font-display text-4xl font-extrabold leading-tight text-brand-950 md:text-5xl">
          Menschen, die für Menschen da sind
        </h1>
        <p class="mt-5 text-lg text-ink-soft">
          Hinter jeder guten Pflege stehen Menschen mit Herz und Können. Unser Team aus
          examinierten Fach- und engagierten Betreuungskräften sorgt dafür, dass Sie sich
          rundum gut aufgehoben fühlen – mit festen Bezugspersonen, die Sie kennen.
        </p>
      </div>
    </div>
  </section>

  <section class="container-page py-16 md:py-20">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {roles.map((r) => (
        <div class="card flex flex-col p-7">
          <span
            class:list={[
              'grid h-16 w-16 place-items-center rounded-2xl text-white shadow-soft',
              r.color === 'accent' ? 'bg-gradient-to-br from-accent-400 to-accent-600' : 'bg-gradient-to-br from-brand-500 to-brand-700',
            ]}
          >
            <Icon name={r.icon} class="h-8 w-8" />
          </span>
          <h2 class="mt-5 font-display text-xl font-bold text-brand-950">{r.title}</h2>
          <p class="mt-2 text-ink-soft">{r.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Einblicke / Team-Galerie (Platzhalter – echte Fotos werden eingefügt) -->
  <section class="bg-sand-50">
    <div class="container-page py-16 md:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow justify-center"><Icon name="users" class="h-4 w-4" /> Einblicke</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold text-brand-950 md:text-4xl">Unser Team in Aktion</h2>
        <p class="mt-4 text-lg text-ink-soft">Echte Menschen, echte Momente – aus unserem Alltag in Reinickendorf.</p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { caption: 'Unser Team', file: '/images/team/team-1.jpg' },
          { caption: 'Im Büro', file: '/images/team/team-2.jpg' },
          { caption: 'Gemeinsame Momente', file: '/images/team/team-3.jpg' },
        ].map((p) => (
          <figure class="flex aspect-[4/3] flex-col items-center justify-center rounded-[2rem] border-2 border-dashed border-sand-300 bg-white p-6 text-center">
            <Icon name="users" class="h-9 w-9 text-sand-400" />
            <figcaption class="mt-3 font-display font-semibold text-ink-soft">{p.caption}</figcaption>
            <span class="mt-1 text-xs text-ink-soft">Foto folgt → <code>{p.file}</code></span>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-page py-16 md:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <p class="eyebrow">Was uns verbindet</p>
          <h2 class="mt-3 font-display text-3xl font-extrabold text-brand-950 md:text-4xl">
            Ein Team, das zusammenhält
          </h2>
          <p class="mt-5 text-lg text-ink-soft">
            Für unser Team sind wir da: Wir nehmen uns Zeit – füreinander und für Sie. Regelmäßige
            Übergaben, kurze Wege und ein wertschätzendes Miteinander sorgen dafür, dass Pflege bei
            uns nicht zur Fließbandarbeit wird. Fortbildungen und gemeinsame Feiern gehören
            selbstverständlich dazu. Das spüren auch die Menschen, die wir versorgen.
          </p>
        </div>
        <div class="rounded-[2.5rem] bg-brand-50 p-8 ring-1 ring-brand-100 md:p-10">
          <Icon name="users" class="h-10 w-10 text-brand-600" />
          <h3 class="mt-4 font-display text-xl font-bold text-brand-950">Werden Sie Teil des Teams</h3>
          <p class="mt-2 text-ink-soft">
            Wir suchen Verstärkung, die unsere Haltung teilt: Pflege mit Herz und Verstand.
            Faire Bedingungen, feste Touren im Kiez und ein Team, das sich gegenseitig stützt.
          </p>
          <a href="/karriere/" class="btn btn-ghost mt-6">
            Offene Stellen ansehen
            <Icon name="arrow" class="h-5 w-5" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    title="Lernen Sie uns persönlich kennen"
    text="Am besten lässt sich Vertrauen im Gespräch aufbauen. Vereinbaren Sie ein kostenloses Kennenlernen – wir freuen uns auf Sie."
  />
</BaseLayout>
