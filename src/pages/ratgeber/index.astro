---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import { ratgeberArticles } from '../../data/site';

const breadcrumbs = [
  { name: 'Startseite', href: '/' },
  { name: 'Ratgeber', href: '/ratgeber/' },
];
---
<BaseLayout
  title="Pflege-Ratgeber – verständlich erklärt"
  description="Der Pflege-Ratgeber der Sozialstation Mobil: Pflegekosten & Pflegegrad, Pflegegrad beantragen, Verhinderungs- & Kurzzeitpflege, häusliche Krankenpflege und Pflege bei Demenz – verständlich erklärt für Berlin."
  breadcrumbs={breadcrumbs}
>
  <section class="bg-gradient-to-b from-brand-50 to-sand-50">
    <div class="container-page py-10 lg:py-16">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 max-w-3xl">
        <p class="eyebrow"><Icon name="clipboard" class="h-4 w-4" /> Ratgeber</p>
        <h1 class="mt-3 font-display text-4xl font-extrabold leading-tight text-brand-950 md:text-5xl">
          Pflege verständlich erklärt
        </h1>
        <p class="mt-5 text-lg text-ink-soft">
          Pflegegrad, Kosten, Anträge, Auszeiten für Angehörige – das deutsche Pflegesystem wirkt
          oft kompliziert. In unserem Ratgeber erklären wir die wichtigsten Themen in klarer Sprache,
          damit Sie gut informiert die richtigen Entscheidungen treffen können.
        </p>
      </div>
    </div>
  </section>

  <section class="container-page py-16 md:py-20">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {ratgeberArticles.map((a) => (
        <a
          href={`/ratgeber/${a.slug}/`}
          class="group card flex flex-col p-6 transition-all duration-200 hover:-translate-y-1 hover:shadow-lift"
        >
          <span class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-accent-500 group-hover:text-white">
            <Icon name={a.icon} class="h-7 w-7" />
          </span>
          <h2 class="mt-5 font-display text-xl font-bold text-brand-950">{a.title}</h2>
          <p class="mt-2 flex-1 text-ink-soft">{a.excerpt}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 font-display font-semibold text-brand-700">
            Artikel lesen
            <Icon name="arrow" class="h-5 w-5 transition-transform group-hover:translate-x-1" />
          </span>
        </a>
      ))}

      <div class="flex flex-col justify-center rounded-[2rem] bg-brand-800 p-7 text-white">
        <Icon name="phone" class="h-9 w-9 text-accent-400" />
        <h2 class="mt-4 font-display text-xl font-bold">Lieber persönlich fragen?</h2>
        <p class="mt-2 text-brand-100">Wir beantworten Ihre Fragen kostenlos und unverbindlich – rufen Sie uns einfach an.</p>
        <a href="/kontakt/" class="btn btn-primary mt-6 w-fit">Beratung anfragen</a>
      </div>
    </div>

    <p class="mt-8 text-sm text-ink-soft">
      Hinweis: Unsere Ratgeber-Artikel dienen der allgemeinen Information und ersetzen keine
      individuelle Beratung. Gesetzliche Beträge (Stand 2025) werden regelmäßig angepasst.
    </p>
  </section>

  <CtaBand />
</BaseLayout>
