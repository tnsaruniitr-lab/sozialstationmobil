---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import CtaBand from '../../components/CtaBand.astro';
import { company, faqs, steps, ratgeberArticles } from '../../data/site';
import { faqSchema } from '../../lib/schema';

const breadcrumbs = [
  { name: 'Startseite', href: '/' },
  { name: 'Ratgeber', href: '/ratgeber/' },
  { name: 'Pflegekosten & Pflegegrad', href: '/ratgeber/pflegekosten-pflegegrad/' },
];

const otherArticles = ratgeberArticles.filter((a) => a.slug !== 'pflegekosten-pflegegrad');

// Leistungsbeträge der Pflegekasse, Stand 2025 (Pflegesachleistung ambulant).
// ⚠️ Beträge werden gesetzlich angepasst – vor Live-Gang prüfen.
const pflegegrade = [
  { grad: 'Pflegegrad 1', sachleistung: '–', pflegegeld: '–', entlastung: '131 €', note: 'Nur Entlastungsbetrag' },
  { grad: 'Pflegegrad 2', sachleistung: '796 €', pflegegeld: '347 €', entlastung: '131 €', note: '' },
  { grad: 'Pflegegrad 3', sachleistung: '1.497 €', pflegegeld: '599 €', entlastung: '131 €', note: '' },
  { grad: 'Pflegegrad 4', sachleistung: '1.859 €', pflegegeld: '800 €', entlastung: '131 €', note: '' },
  { grad: 'Pflegegrad 5', sachleistung: '2.299 €', pflegegeld: '990 €', entlastung: '131 €', note: '' },
];
---
<BaseLayout
  title="Pflegekosten & Pflegegrad – Was zahlt die Pflegekasse?"
  description="Was kostet ein ambulanter Pflegedienst? Übersicht zu Pflegegraden, Leistungsbeträgen der Pflegekasse (Stand 2025), Entlastungsbetrag 131 € und Pflegegrad-Antrag. Verständlich erklärt von der Sozialstation Mobil Berlin."
  breadcrumbs={breadcrumbs}
  schema={[faqSchema(faqs)]}
>
  <section class="bg-gradient-to-b from-brand-50 to-sand-50">
    <div class="container-page py-10 lg:py-16">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 max-w-3xl">
        <p class="eyebrow">Ratgeber</p>
        <h1 class="mt-3 font-display text-4xl font-extrabold leading-tight text-brand-950 md:text-5xl">
          Pflegekosten &amp; Pflegegrad einfach erklärt
        </h1>
        <p class="mt-5 text-lg text-ink-soft">
          Was kostet ein ambulanter Pflegedienst – und wer zahlt das eigentlich? Hier finden Sie
          verständliche Antworten zu Pflegegraden, den Leistungen der Pflege- und Krankenkasse
          und dem Weg zu Ihrem Pflegegrad.
        </p>
      </div>
    </div>
  </section>

  <div class="container-page grid gap-12 py-16 md:py-20 lg:grid-cols-[1fr_320px]">
    <article class="prose-care max-w-none min-w-0">
      <h2>Wer übernimmt die Kosten der ambulanten Pflege?</h2>
      <p>
        Für gesetzlich Versicherte mit anerkanntem Pflegegrad tragen in der Regel zwei Stellen
        den Großteil der Kosten. Welche Kasse zuständig ist, hängt von der Art der Leistung ab:
      </p>

      <div class="not-prose my-8 grid gap-5 sm:grid-cols-2">
        <div class="card p-6">
          <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600">
            <Icon name="heart-hands" class="h-6 w-6" />
          </span>
          <h3 class="mt-4 font-display text-lg font-bold text-brand-950">Pflegekasse (SGB XI)</h3>
          <p class="mt-2 text-ink-soft">
            Zahlt für die <strong class="text-ink">Grundpflege</strong> und Betreuung –
            z. B. Hilfe bei Körperpflege, Ernährung und Mobilität. Höhe abhängig vom Pflegegrad.
          </p>
        </div>
        <div class="card p-6">
          <span class="grid h-12 w-12 place-items-center rounded-2xl bg-accent-50 text-accent-600">
            <Icon name="stethoscope" class="h-6 w-6" />
          </span>
          <h3 class="mt-4 font-display text-lg font-bold text-brand-950">Krankenkasse (SGB V)</h3>
          <p class="mt-2 text-ink-soft">
            Zahlt für die ärztlich verordnete <strong class="text-ink">Behandlungspflege</strong> –
            z. B. Medikamentengabe, Injektionen oder Verbandwechsel. Für Sie meist kostenfrei.
          </p>
        </div>
      </div>

      <h2>Die Leistungsbeträge der Pflegekasse im Überblick</h2>
      <p>
        Mit einem anerkannten Pflegegrad stehen Ihnen monatliche Leistungen zu. Wenn ein
        ambulanter Pflegedienst die Pflege übernimmt, spricht man von der
        <strong>Pflegesachleistung</strong>. Übernehmen Angehörige die Pflege, gibt es
        stattdessen das <strong>Pflegegeld</strong>. Beides lässt sich auch kombinieren.
      </p>

      <div class="not-prose my-8 overflow-x-auto rounded-3xl border border-sand-200 shadow-soft">
        <table class="w-full min-w-[34rem] border-collapse bg-white text-left">
          <thead>
            <tr class="bg-brand-800 text-white">
              <th class="px-5 py-4 font-display text-sm font-bold">Pflegegrad</th>
              <th class="px-5 py-4 font-display text-sm font-bold">Pflegesachleistung</th>
              <th class="px-5 py-4 font-display text-sm font-bold">Pflegegeld</th>
              <th class="px-5 py-4 font-display text-sm font-bold">Entlastungsbetrag</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-sand-200">
            {pflegegrade.map((p) => (
              <tr class="text-ink">
                <th scope="row" class="px-5 py-4 font-display font-bold text-brand-900">{p.grad}</th>
                <td class="px-5 py-4 font-semibold">{p.sachleistung}</td>
                <td class="px-5 py-4">{p.pflegegeld}</td>
                <td class="px-5 py-4">{p.entlastung}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="not-prose text-sm text-ink-soft">
        Monatliche Beträge, Stand 2025 (ambulante Leistungen). Die Werte werden gesetzlich
        angepasst – wir nennen Ihnen im Beratungsgespräch gerne die aktuell gültigen Beträge.
      </p>

      <h2>Der Entlastungsbetrag: 131 € pro Monat für alle</h2>
      <p>
        Zusätzlich steht jedem Menschen mit Pflegegrad 1 bis 5 ein <strong>Entlastungsbetrag von
        131 € monatlich</strong> zu (§ 45b SGB XI). Diesen können Sie z. B. für Betreuung,
        Begleitung oder hauswirtschaftliche Hilfe einsetzen. Nicht genutzte Beträge verfallen
        nicht sofort – sie lassen sich innerhalb des Jahres ansparen.
      </p>

      <h2>So beantragen Sie einen Pflegegrad</h2>
      <p>
        Der Weg zum Pflegegrad ist einfacher, als viele denken. In vier Schritten zum Ziel –
        und wir unterstützen Sie gerne dabei:
      </p>
      <ol class="not-prose my-8 grid gap-4">
        {steps.map((step, i) => (
          <li class="flex gap-4 rounded-2xl bg-white p-5 shadow-soft ring-1 ring-sand-200">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-600 font-display font-bold text-white">{i + 1}</span>
            <span>
              <span class="block font-display font-bold text-brand-950">{step.title}</span>
              <span class="mt-1 block text-ink-soft">{step.text}</span>
            </span>
          </li>
        ))}
      </ol>
      <p>
        Tipp: Bereiten Sie sich auf den Begutachtungstermin durch den Medizinischen Dienst (MD)
        gut vor und führen Sie ein kurzes Pflegetagebuch. Gerne geben wir Ihnen dazu hilfreiche
        Hinweise an die Hand.
      </p>
    </article>

    <!-- Sidebar -->
    <aside class="lg:sticky lg:top-28 lg:h-fit">
      <div class="rounded-[2rem] bg-brand-800 p-7 text-white shadow-lift">
        <Icon name="euro" class="h-10 w-10 text-accent-400" />
        <h2 class="mt-4 font-display text-xl font-bold">Kostenlose Kostenübersicht</h2>
        <p class="mt-2 text-brand-100">
          Wir erstellen Ihnen unverbindlich eine transparente Übersicht – inklusive möglichem
          Eigenanteil für Ihre persönliche Situation.
        </p>
        <a href="/kontakt/" class="btn btn-primary mt-6 w-full">Beratung anfragen</a>
        <a href={`tel:${company.phoneHref}`} class="mt-4 flex items-center justify-center gap-2 font-display font-bold text-white hover:text-accent-300">
          <Icon name="phone" class="h-5 w-5" />
          {company.phone}
        </a>
      </div>
    </aside>
  </div>

  <!-- FAQ -->
  <section class="bg-white">
    <div class="container-page py-16 md:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow justify-center">Häufige Fragen</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold text-brand-950 md:text-4xl">
          Ihre Fragen zu Pflege, Kosten &amp; Pflegegrad
        </h2>
      </div>
      <div class="mt-12">
        <FaqAccordion items={faqs} />
      </div>
    </div>
  </section>

  <!-- Weitere Ratgeber-Artikel -->
  <section class="container-page py-16 md:py-20">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <h2 class="font-display text-2xl font-extrabold text-brand-950 md:text-3xl">Weitere Ratgeber-Themen</h2>
      <a href="/ratgeber/" class="inline-flex items-center gap-1.5 font-display font-semibold text-brand-700 hover:text-accent-600">
        Alle Artikel
        <Icon name="arrow" class="h-5 w-5" />
      </a>
    </div>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {otherArticles.map((art) => (
        <a href={`/ratgeber/${art.slug}/`} class="group card flex flex-col p-5 transition-all hover:-translate-y-1 hover:shadow-lift">
          <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-accent-500 group-hover:text-white">
            <Icon name={art.icon} class="h-6 w-6" />
          </span>
          <span class="mt-4 font-display font-bold text-brand-950">{art.title}</span>
          <span class="mt-1 text-sm text-ink-soft">{art.excerpt}</span>
        </a>
      ))}
    </div>
  </section>

  <CtaBand />
</BaseLayout>
