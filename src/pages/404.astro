---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { company, services } from '../data/site';
---
<BaseLayout title="Seite nicht gefunden" description="Die aufgerufene Seite wurde nicht gefunden." noindex>
  <section class="container-page flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <span class="grid h-20 w-20 place-items-center rounded-3xl bg-brand-50 text-brand-600">
      <Icon name="pin" class="h-10 w-10" />
    </span>
    <p class="mt-6 font-display text-6xl font-extrabold text-brand-200">404</p>
    <h1 class="mt-2 font-display text-3xl font-extrabold text-brand-950 md:text-4xl">Diese Seite haben wir leider nicht gefunden</h1>
    <p class="mt-4 max-w-lg text-lg text-ink-soft">
      Vielleicht wurde die Seite verschoben. Kehren Sie zur Startseite zurück oder rufen Sie uns
      an – wir helfen Ihnen gerne weiter.
    </p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a href="/" class="btn btn-ghost">Zur Startseite</a>
      <a href={`tel:${company.phoneHref}`} class="btn btn-secondary"><Icon name="phone" class="h-5 w-5" /> {company.phone}</a>
    </div>
    <div class="mt-10 flex flex-wrap justify-center gap-2">
      {services.slice(0, 5).map((s) => (
        <a href={`/leistungen/${s.slug}/`} class="rounded-full bg-white px-4 py-2 text-sm font-semibold text-brand-700 shadow-soft ring-1 ring-sand-200 hover:bg-brand-50">{s.title}</a>
      ))}
    </div>
  </section>
</BaseLayout>
