---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { company } from '../data/site';

const breadcrumbs = [
  { name: 'Startseite', href: '/' },
  { name: 'Karriere', href: '/karriere/' },
];

const benefits = [
  { icon: 'euro', title: 'Faire Bezahlung', text: 'Verlässliche, leistungsgerechte Vergütung plus Zuschläge für Wochenende und Feiertage.' },
  { icon: 'route', title: 'Touren im Kiez', text: 'Kurze Wege in Reinickendorf statt langer Fahrten quer durch Berlin.' },
  { icon: 'calendar', title: 'Planbare Dienste', text: 'Verlässliche Dienstpläne, Wunschfrei und Rücksicht auf Ihre Lebenssituation.' },
  { icon: 'award', title: 'Weiterbildung', text: 'Wir fördern Fort- und Weiterbildungen – z. B. zur Wund- oder Diabetes-Fachkraft.' },
  { icon: 'users', title: 'Herzliches Team', text: 'Ein kleines Team, das sich gegenseitig stützt – ohne Anonymität großer Konzerne.' },
  { icon: 'shield', title: 'Sicherer Arbeitsplatz', text: 'Unbefristete Anstellung in Voll- oder Teilzeit in einer krisensicheren Branche.' },
];

const jobs = [
  {
    title: 'Pflegefachkraft / Examinierte Pflegekraft (m/w/d)',
    type: 'Voll- oder Teilzeit',
    text: 'Sie übernehmen Grund- und Behandlungspflege bei festen Patient:innen in Ihrer Tour und arbeiten eng mit Ärzt:innen zusammen.',
    need: ['Abgeschlossene Ausbildung in der (Alten-)Pflege', 'Empathie und Zuverlässigkeit', 'Führerschein von Vorteil'],
  },
  {
    title: 'Pflegehilfskraft (m/w/d)',
    type: 'Teilzeit / Minijob',
    text: 'Sie unterstützen bei der Grundpflege und im Alltag unserer Patient:innen – ein sinnstiftender Einstieg in die Pflege.',
    need: ['Erste Erfahrung in der Pflege wünschenswert', 'Freude am Umgang mit Menschen', 'Zuverlässigkeit'],
  },
  {
    title: 'Betreuungskraft nach § 53c (m/w/d)',
    type: 'Teilzeit',
    text: 'Sie schenken Zeit und Gesellschaft, begleiten zu Terminen und entlasten Angehörige im Rahmen der Betreuungsleistungen.',
    need: ['Qualifikation nach § 53c SGB XI (oder Bereitschaft dazu)', 'Geduld und Einfühlungsvermögen'],
  },
];

const subject = encodeURIComponent('Bewerbung bei der Sozialstation Mobil');
---
<BaseLayout
  title="Karriere – Pflegejobs in Berlin-Reinickendorf"
  description="Pflegejobs mit Sinn bei der Sozialstation Mobil in Berlin-Reinickendorf: Pflegefachkraft, Pflegehilfskraft & Betreuungskraft (m/w/d). Feste Touren im Kiez, faire Bezahlung, planbare Dienste. Jetzt bewerben!"
  breadcrumbs={breadcrumbs}
>
  <section class="relative overflow-hidden bg-brand-800 text-white">
    <div class="pointer-events-none absolute -right-20 -top-24 h-80 w-80 rounded-full bg-brand-700/60"></div>
    <div class="pointer-events-none absolute bottom-0 left-1/3 text-accent-400/20"><Icon name="heart-hands" class="h-72 w-72" /></div>
    <div class="container-page relative py-12 lg:py-20">
      <Breadcrumbs items={breadcrumbs.map((b, i) => ({ ...b, href: b.href }))} />
      <div class="mt-8 max-w-3xl">
        <p class="eyebrow text-accent-300">Karriere bei Sozialstation Mobil</p>
        <h1 class="mt-3 font-display text-4xl font-extrabold leading-tight md:text-5xl">
          Pflege ist Ihre Berufung? Dann passen Sie zu uns.
        </h1>
        <p class="mt-5 text-lg text-brand-100">
          Bei uns arbeiten Sie nah am Menschen – mit festen Touren im Kiez, einem herzlichen
          Team und der Wertschätzung, die gute Pflege verdient. Werden Sie Teil der
          Sozialstation Mobil in Berlin-Reinickendorf.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="#stellen" class="btn btn-primary">Offene Stellen</a>
          <a href={`mailto:${company.email}?subject=${subject}`} class="btn btn-secondary">Initiativ bewerben</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="container-page py-16 md:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow justify-center">Ihre Vorteile</p>
      <h2 class="mt-3 font-display text-3xl font-extrabold text-brand-950 md:text-4xl">Was wir Ihnen bieten</h2>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {benefits.map((b) => (
        <div class="card p-6">
          <span class="grid h-12 w-12 place-items-center rounded-2xl bg-accent-50 text-accent-600">
            <Icon name={b.icon} class="h-6 w-6" />
          </span>
          <h3 class="mt-4 font-display text-lg font-bold text-brand-950">{b.title}</h3>
          <p class="mt-1.5 text-[0.95rem] text-ink-soft">{b.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Stellen -->
  <section id="stellen" class="bg-white scroll-mt-28">
    <div class="container-page py-16 md:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow justify-center">Offene Stellen</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold text-brand-950 md:text-4xl">Aktuelle Stellenangebote</h2>
        <p class="mt-4 text-lg text-ink-soft">Wir freuen uns auf Ihre Bewerbung – auch initiativ.</p>
      </div>

      <div class="mx-auto mt-12 max-w-4xl space-y-5">
        {jobs.map((job) => (
          <article class="card p-6 md:p-8">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <span class="inline-flex items-center gap-2 rounded-full bg-brand-50 px-3 py-1 text-sm font-semibold text-brand-700">
                  <Icon name="clock" class="h-4 w-4" /> {job.type}
                </span>
                <h3 class="mt-3 font-display text-xl font-bold text-brand-950">{job.title}</h3>
              </div>
              <a
                href={`mailto:${company.email}?subject=${encodeURIComponent('Bewerbung: ' + job.title)}`}
                class="btn btn-primary shrink-0"
              >
                Jetzt bewerben
              </a>
            </div>
            <p class="mt-4 text-ink-soft">{job.text}</p>
            <ul class="mt-4 flex flex-wrap gap-x-6 gap-y-2">
              {job.need.map((n) => (
                <li class="flex items-center gap-2 text-sm text-ink">
                  <Icon name="check" class="h-4 w-4 text-accent-500" /> {n}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Bewerbungsprozess -->
  <section class="container-page py-16 md:py-20">
    <div class="rounded-[2.5rem] bg-brand-50 p-8 ring-1 ring-brand-100 md:p-12">
      <div class="grid items-center gap-8 lg:grid-cols-[1.3fr_1fr]">
        <div>
          <p class="eyebrow">So einfach bewerben Sie sich</p>
          <h2 class="mt-3 font-display text-2xl font-extrabold text-brand-950 md:text-3xl">
            Kein langes Anschreiben nötig
          </h2>
          <p class="mt-4 text-ink-soft">
            Schreiben Sie uns einfach eine kurze E-Mail oder rufen Sie an – wir melden uns
            zeitnah und lernen Sie in einem lockeren Gespräch kennen. Zeugnisse können Sie
            auch später nachreichen.
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a href={`mailto:${company.email}?subject=${subject}`} class="btn btn-primary">
              <Icon name="mail" class="h-5 w-5" /> {company.email}
            </a>
            <a href={`tel:${company.phoneHref}`} class="btn btn-secondary">
              <Icon name="phone" class="h-5 w-5" /> {company.phone}
            </a>
          </div>
        </div>
        <ul class="space-y-4">
          {['Kurze Nachricht oder Anruf', 'Persönliches Kennenlernen', 'Schnupper-Tag in der Praxis', 'Willkommen im Team'].map((step, i) => (
            <li class="flex items-center gap-4">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-brand-600 font-display font-bold text-white">{i + 1}</span>
              <span class="font-semibold text-brand-900">{step}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
