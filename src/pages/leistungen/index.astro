---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CtaBand from '../../components/CtaBand.astro';
import { services, usps } from '../../data/site';

const breadcrumbs = [
  { name: 'Startseite', href: '/' },
  { name: 'Leistungen', href: '/leistungen/' },
];
---
<BaseLayout
  title="Leistungen – Ambulante Pflege & Betreuung in Berlin"
  description="Alle Leistungen der Sozialstation Mobil: Behandlungspflege, Grundpflege, diabetologische Fachpflege, Wundmanagement, Hauswirtschaft, Entlastungsleistungen und Demenz-WG in Berlin-Reinickendorf."
  breadcrumbs={breadcrumbs}
>
  <section class="bg-gradient-to-b from-brand-50 to-sand-50">
    <div class="container-page py-10 lg:py-16">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 max-w-3xl">
        <p class="eyebrow">Unser Leistungsangebot</p>
        <h1 class="mt-3 font-display text-4xl font-extrabold leading-tight text-brand-950 md:text-5xl">
          Pflege, Betreuung und Versorgung – individuell für Sie
        </h1>
        <p class="mt-5 text-lg text-ink-soft">
          Ob medizinische Behandlungspflege, liebevolle Grundpflege oder Begleitung im Alltag:
          Bei der Sozialstation Mobil erhalten Sie alle Leistungen aus einer Hand – abgestimmt
          auf Ihren Pflegegrad und Ihre persönliche Situation.
        </p>
      </div>
    </div>
  </section>

  <section class="container-page py-16 md:py-20">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => <ServiceCard service={service} />)}
    </div>
  </section>

  <section class="bg-white">
    <div class="container-page py-16 md:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow justify-center">Warum Sozialstation Mobil</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold text-brand-950 md:text-4xl">
          Verlässliche Pflege, der Sie vertrauen können
        </h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {usps.map((u) => (
          <div class="card p-6">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-accent-50 text-accent-600">
              <Icon name={u.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-4 font-display text-lg font-bold text-brand-950">{u.title}</h3>
            <p class="mt-1.5 text-[0.95rem] text-ink-soft">{u.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
