---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import CtaBand from '../../components/CtaBand.astro';
import { services, company, serviceExtraFaqs, type Service } from '../../data/site';
import { serviceSchema, faqSchema } from '../../lib/schema';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: Service;
}
const { service } = Astro.props;
const url = `/leistungen/${service.slug}/`;

const breadcrumbs = [
  { name: 'Startseite', href: '/' },
  { name: 'Leistungen', href: '/leistungen/' },
  { name: service.title, href: url },
];

// Abgeleitete FAQ (aus den einzigartigen Inhalten je Leistung) + kuratierte Zusatzfragen (AEO)
const serviceFaqs = [
  { question: `Was bedeutet ${service.title}?`, answer: service.answer },
  { question: `Wer übernimmt die Kosten für ${service.title}?`, answer: service.funding },
  ...(serviceExtraFaqs[service.slug] ?? []),
];

const others = services.filter((s) => s.slug !== service.slug).slice(0, 3);

const metaDescription = `${service.short} ✔ Sozialstation Mobil – Ihr ambulanter Pflegedienst in Berlin-Reinickendorf. Jetzt kostenlos beraten lassen ☎ ${company.phone}.`;
---
<BaseLayout
  title={`${service.title} in Berlin-Reinickendorf`}
  description={metaDescription}
  breadcrumbs={breadcrumbs}
  schema={[
    serviceSchema({ slug: service.slug, name: service.title, description: service.short, url }),
    faqSchema(serviceFaqs),
  ]}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-50 to-sand-50">
    <div class="pointer-events-none absolute right-0 top-0 h-72 w-72 rounded-full bg-accent-100/40 blur-2xl"></div>
    <div class="container-page relative py-10 lg:py-14">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 grid items-center gap-10 lg:grid-cols-[1.4fr_1fr]">
        <div>
          <p class="eyebrow">Pflegeleistung</p>
          <h1 class="mt-3 font-display text-4xl font-extrabold leading-tight text-brand-950 md:text-5xl">
            {service.title}
          </h1>
          <p class="mt-5 max-w-xl text-lg text-ink-soft">{service.answer}</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={`tel:${company.phoneHref}`} class="btn btn-primary">
              <Icon name="phone" class="h-5 w-5" />
              {company.phone}
            </a>
            <a href="/kontakt/" class="btn btn-secondary">Kostenlose Beratung</a>
          </div>
        </div>
        <div class="relative mx-auto w-full max-w-sm">
          <div class="card flex flex-col items-center p-10 text-center">
            <span class="grid h-24 w-24 place-items-center rounded-3xl bg-gradient-to-br from-brand-500 to-brand-700 text-white shadow-lift">
              <Icon name={service.icon} class="h-12 w-12" />
            </span>
            {service.highlight && (
              <span class="mt-6 inline-flex items-center gap-2 rounded-full bg-accent-50 px-4 py-2 font-semibold text-accent-700">
                <Icon name="check-circle" class="h-5 w-5" />
                {service.highlight}
              </span>
            )}
            <p class="mt-4 text-sm text-ink-soft">Teil unseres Versorgungsangebots im Berliner Norden.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DETAIL -->
  <section class="container-page py-16 md:py-20">
    <div class="grid gap-12 lg:grid-cols-[1.5fr_1fr]">
      <div>
        <p class="eyebrow">Im Detail</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold text-brand-950">Das leisten wir für Sie</h2>
        <p class="prose-care mt-4">{service.intro}</p>
        <ul class="prose-care mt-6">
          {service.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <aside class="space-y-6">
        <div class="card p-7">
          <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600">
            <Icon name="users" class="h-6 w-6" />
          </span>
          <h3 class="mt-4 font-display text-lg font-bold text-brand-950">Für wen geeignet?</h3>
          <p class="mt-2 text-ink-soft">{service.audience}</p>
        </div>
        <div class="rounded-[2rem] bg-brand-800 p-7 text-white">
          <span class="grid h-12 w-12 place-items-center rounded-2xl bg-white/10 text-accent-300">
            <Icon name="euro" class="h-6 w-6" />
          </span>
          <h3 class="mt-4 font-display text-lg font-bold">Wer übernimmt die Kosten?</h3>
          <p class="mt-2 text-brand-100">{service.funding}</p>
          <a href="/ratgeber/pflegekosten-pflegegrad/" class="mt-4 inline-flex items-center gap-1.5 font-semibold text-accent-300 hover:text-accent-200">
            Mehr zu Kosten &amp; Pflegegrad
            <Icon name="arrow" class="h-4 w-4" />
          </a>
        </div>
      </aside>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white">
    <div class="container-page py-16 md:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow justify-center">Häufige Fragen</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold text-brand-950">Fragen zu {service.title}</h2>
      </div>
      <div class="mt-10">
        <FaqAccordion items={serviceFaqs} />
      </div>
    </div>
  </section>

  <!-- WEITERE LEISTUNGEN -->
  <section class="container-page py-16 md:py-20">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="eyebrow">Weitere Leistungen</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold text-brand-950">Das könnte Sie auch interessieren</h2>
      </div>
      <a href="/leistungen/" class="inline-flex items-center gap-1.5 font-display font-semibold text-brand-700 hover:text-accent-600">
        Alle Leistungen
        <Icon name="arrow" class="h-5 w-5" />
      </a>
    </div>
    <div class="mt-8 grid gap-6 sm:grid-cols-3">
      {others.map((o) => (
        <a href={`/leistungen/${o.slug}/`} class="group card flex items-start gap-4 p-5 transition-all hover:-translate-y-1 hover:shadow-lift">
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-accent-500 group-hover:text-white">
            <Icon name={o.icon} class="h-6 w-6" />
          </span>
          <span>
            <span class="block font-display font-bold text-brand-950">{o.title}</span>
            <span class="mt-1 block text-sm text-ink-soft">{o.short}</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <CtaBand />
</BaseLayout>
